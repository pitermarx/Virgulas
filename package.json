{
    "name": "virgulas",
    "version": "1.0.0",
    "description": "Local-first browser outliner",
    "type": "module",
    "scripts": {
        "test": "node tests/run-all-tests.mjs",
        "test:e2e": "playwright test --grep-invert @unit",
        "test:unit": "playwright test --grep @unit",
        "vendor:sync": "node scripts/sync-vendor.mjs",
        "serve": "serve -p 3000 source",
        "postinstall": "npm run vendor:sync",
        "db:start": "supabase start --ignore-health-check",
        "db:stop": "supabase stop --no-backup --yes"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "serve": "^14.2.6",
        "supabase": "^2.92.1"
    },
    "dependencies": {
        "@preact/signals": "^2.9.0",
        "@supabase/supabase-js": "^2.104.0",
        "htm": "^3.1.1",
        "preact": "^10.29.1"
    }
}