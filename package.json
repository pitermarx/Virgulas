{
    "name": "virgulas",
    "version": "1.5.2",
    "description": "Local-first browser outliner",
    "type": "module",
    "scripts": {
        "test": "node tests/run-all-tests.mjs",
        "test:e2e": "playwright test --grep-invert @unit",
        "test:unit": "playwright test --grep @unit",
        "vendor:sync": "node scripts/sync-vendor.mjs",
        "sw:bump": "node scripts/bump-sw-caches.mjs",
        "sw:hooks": "node scripts/install-hooks.mjs",
        "commit:check": "node scripts/check-conventional-commits.mjs",
        "commit:check:range": "node scripts/check-conventional-commits.mjs --range",
        "release:plan": "node scripts/release-from-commits.mjs",
        "version:stamp": "node scripts/stamp-app-version.mjs",
        "serve": "serve -p 3000 source",
        "postinstall": "npm run vendor:sync && npm run sw:bump",
        "db:start": "supabase start --ignore-health-check",
        "db:stop": "supabase stop --no-backup --yes"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "serve": "^14.2.6",
        "supabase": "^2.93.0"
    },
    "dependencies": {
        "@preact/signals": "^2.9.0",
        "@supabase/supabase-js": "^2.104.0",
        "dompurify": "^3.4.1",
        "htm": "^3.1.1",
        "marked": "^18.0.2",
        "preact": "^10.29.1"
    }
}
